configfile: "config/config.yaml"

# Escaneia automaticamente todos os arquivos da Illumina colados na pasta
INDS = glob_wildcards("data/raw/reads/{ind}.FASTQ.gz").ind

def nicotiana_docker_run(image, cmd):
    return f"docker run --rm -u $(id -u):$(id -g) -v $(pwd):$(pwd) -w $(pwd) {image} {cmd}"

# --- REGRA ALVO DO STEP 1 ---
rule all:
    input:
        expand("results/qc/fastqc/raw/{ind}", ind=INDS),
        expand("results/qc/fastqc/trimmed/{ind}", ind=INDS),
        "results/qc/read_counts.txt",
        "results/qc/trimmed_count.txt"

# ==========================================
# 01 STEP: RAW STAT ASSESSMENT
# ==========================================
rule fastqc_raw:
    input: "data/raw/reads/{ind}.FASTQ.gz"
    output: out_dir=directory("results/qc/fastqc/raw/{ind}")
    shell: 
        """
        mkdir -p {output.out_dir}
        docker run --rm -u $(id -u):$(id -g) -v $(pwd):$(pwd) -w $(pwd) staphb/fastqc:0.12.1 \
        fastqc -q {input} -o {output.out_dir}
        """

rule fastq_stats_raw:
    input: "data/raw/reads/{ind}.FASTQ.gz"
    output: "results/qc/stats/raw/{ind}.RAW_stats.txt"
    shell: 
        """
        # Extrai a linha 'reads', formata tabulado com o nome da amostra e salva
        docker run --rm -i -u $(id -u):$(id -g) -v $(pwd):$(pwd) -w $(pwd) quay.io/biocontainers/ea-utils:1.1.2.779--h9dd4a16_0 \
        sh -c "fastq-stats {input} | grep '^reads' | awk -v smp='{wildcards.ind}' '{{print smp \\\"\\\\t\\\" \\$2}}' > {output}"
        """

# ==========================================
# 02 STEP: TRIMMING (M_TRIM2)
# ==========================================
rule fastq_mcf:
    input: 
        read="data/raw/reads/{ind}.FASTQ.gz",
        adapter="data/raw/illumina_adapter.fasta"
    output: "results/trimmed/reads/{ind}.trimmed.fastq.gz"
    shell: 
        """
        docker run --rm -u $(id -u):$(id -g) -v $(pwd):$(pwd) -w $(pwd) quay.io/biocontainers/ea-utils:1.1.2.779--h9dd4a16_0 \
        fastq-mcf -q 30 -l 50 {input.adapter} {input.read} -o {output}
        """

# ==========================================
# 03 STEP: TRIMMED STAT ASSESSMENT
# ==========================================
rule fastqc_trimmed:
    input: "results/trimmed/reads/{ind}.trimmed.fastq.gz"
    output: out_dir=directory("results/qc/fastqc/trimmed/{ind}")
    shell: 
        """
        mkdir -p {output.out_dir}
        docker run --rm -u $(id -u):$(id -g) -v $(pwd):$(pwd) -w $(pwd) staphb/fastqc:0.12.1 \
        fastqc -q {input} -o {output.out_dir}
        """

rule fastq_stats_trimmed:
    input: "results/trimmed/reads/{ind}.trimmed.fastq.gz"
    output: "results/qc/stats/trimmed/{ind}.q30l50_stats.txt"
    shell: 
        """
        docker run --rm -i -u $(id -u):$(id -g) -v $(pwd):$(pwd) -w $(pwd) quay.io/biocontainers/ea-utils:1.1.2.779--h9dd4a16_0 \
        sh -c "fastq-stats {input} | grep '^reads' | awk -v smp='{wildcards.ind}' '{{print smp \\\"\\\\t\\\" \\$2}}' > {output}"
        """

# ==========================================
# AGGREGAÇÃO (SUBSTITUI O LAÇO 'FOR' DO BASH)
# ==========================================
rule merge_stats:
    input:
        raw=expand("results/qc/stats/raw/{ind}.RAW_stats.txt", ind=INDS),
        trim=expand("results/qc/stats/trimmed/{ind}.q30l50_stats.txt", ind=INDS)
    output:
        raw_counts="results/qc/read_counts.txt",
        trim_counts="results/qc/trimmed_count.txt"
    shell:
        """
        # Adiciona os cabeçalhos para o Excel
        echo -e "sample\\ttotal_RAW_reads" > {output.raw_counts}
        echo -e "sample\\tq30_l50_kept" > {output.trim_counts}
        
        # Concatena todos os arquivos intermediários
        cat {input.raw} >> {output.raw_counts}
        cat {input.trim} >> {output.trim_counts}
        """
